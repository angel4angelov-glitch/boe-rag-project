# Required
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# Reranking (primary)
COHERE_API_KEY=your_key_here

# Optional - for web search fallback in CRAG
TAVILY_API_KEY=your_key_here

# Optional - LangSmith tracing (smith.langchain.com).
# When LANGSMITH_TRACING=true, every pipeline.run() call and every LLM
# invocation is captured as a nested trace for debugging + demo
# screenshots. Leave unset in CI/tests — conftest.py forces it off there.
# Free-tier quota is 5k traces/month; run_ragas.py explicitly disables
# tracing during RAGAS runs to avoid burning quota on evaluator calls.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_PROJECT=boe-rag
